# Syncthing ignore patterns for jt-vault
# (Mac side will get the same .stignore via sync, so changes here propagate.)

# Git internals — never sync
.git
.git/**

# Obsidian workspace state (per-device, conflicts otherwise)
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# Editor swap files
*.swp
*.swo
*~
.#*

# Syncthing internals
.stversions
.stfolder
.stignore.tmp

# Conflict markers (always ignored by syncthing but explicit)
*.sync-conflict-*

# SQLite WAL/SHM sidecar files — volatile, host-specific, NEVER sync
# (the .db file itself does sync; only the journal must stay local)
*.db-wal
*.db-shm
*.db-journal
